{
    "testsPort": 80,
    "config": {
        "WP_HOME": "http://mywp.site",
        "WP_SITEURL": "http://mywp.site"
    },
    "phpVersion": "8.0",
    "plugins": [
        "./resources/e2e-snippets"
    ],
    "mappings": {
        "wp-cli.yml": "./wp-cli.yml",
        "wp-content/files": "./resources/files"
    },
    "lifecycleScripts": {
        "afterStart": "node bin/test-env-setup.js",
        "afterClean": "node bin/test-env-clean.js"
    }
}
