{
  "name": "mollie-payments-for-woocommerce",
  "version": "5.6.1",
  "license": "GPL-2.0-or-later",
  "description": "Accept payments in WooCommerce with the official Mollie plugin",
  "keywords": [
    "Mollie",
    "WooCommerce",
    "WordPress"
  ],
  "authors": [
    {
      "name": "Syde GmbH",
      "homepage": "https://syde.com/",
      "email": "hello@syde.com",
      "role": "Company"
    },
    {
      "name": "Mollie B.V.",
      "email": "info@mollie.com"
    }
  ],
  "homepage": "https://github.com/mollie/WooCommerce",
  "repository": {
    "type": "git",
    "url": "git@github.com:mollie/WooCommerce.git"
  },
  "devDependencies": {
    "@inpsyde/playwright-utils": "^5.1.0",
    "@playwright/test": "^1.59.0",
    "@woocommerce/dependency-extraction-webpack-plugin": "3.0.1",
    "@wordpress/scripts": "^30.24.0",
    "wp-pot": "^1.10.2",
    "dotenv": "^16.3.1",
    "mollie-api-typescript": "^1.0.2",
    "yarn": "^1.22.21",
    "@types/node": "^20.8.4",
    "@wordpress/env": "^10.30.0"
  },
  "scripts": {
    "build": "wp-scripts build",
    "start": "wp-scripts start",
    "lint:md": "wp-scripts lint-md-docs *.md",
    "lint:js": "wp-scripts lint-js resources/js/src/*",
    "lint:style": "wp-scripts lint-style resources/scss/*.scss",
    "lint:js:fix": "wp-scripts lint-js resources/js/src/* --fix",
    "lint:style:fix": "wp-scripts lint-style resources/scss/*.scss --fix",
    "lint:php": "yarn phpcs && yarn psalm",
    "lint:php-fix": "vendor/bin/phpcbf --parallel=8",
    
    "e2e:setup:tests": "npm install && npx playwright install",

    "e2e:test:payment-api:plugin-foundation": "npx playwright test --project \"shard:payment-api:plugin-foundation\" --workers=1",
    "e2e:test:payment-api:merchant-setup": "npx playwright test --project \"shard:payment-api:merchant-setup\" --workers=1",
    "e2e:test:payment-api:plugin-settings:advanced": "npx playwright test --project \"shard:payment-api:plugin-settings:advanced\" --workers=1",
    "e2e:test:payment-api:plugin-settings:api-keys": "npx playwright test --project \"shard:payment-api:plugin-settings:api-keys\" --workers=1",
    "e2e:test:payment-api:plugin-settings:gateway": "npx playwright test --project \"shard:payment-api:plugin-settings:gateway\" --workers=1",
    "e2e:test:payment-api:plugin-settings:surcharge": "npx playwright test --project \"shard:payment-api:plugin-settings:surcharge\" --workers=1",
    "e2e:test:payment-api:frontend-ui": "npx playwright test --project \"shard:payment-api:frontend-ui\" --workers=1",
    "e2e:test:payment-api:transaction:eur-block": "npx playwright test --project \"shard:payment-api:transaction:eur-block\" --workers=4",
    "e2e:test:payment-api:transaction:eur-classic": "npx playwright test --project \"shard:payment-api:transaction:eur-classic\" --workers=4",
    "e2e:test:payment-api:transaction:non-eur-block": "npx playwright test --project \"shard:payment-api:transaction:non-eur-block\" --workers=1",
    "e2e:test:payment-api:transaction:non-eur-classic": "npx playwright test --project \"shard:payment-api:transaction:non-eur-classic\" --workers=1",
    "e2e:test:payment-api:transaction:eur-block-card-disabled-components": "npx playwright test --project \"shard:payment-api:transaction:eur-block-card-disabled-components\" --workers=1",
    "e2e:test:payment-api:transaction:eur-classic-card-disabled-components": "npx playwright test --project \"shard:payment-api:transaction:eur-classic-card-disabled-components\" --workers=1",
    "e2e:test:payment-api:refund": "npx playwright test --project \"shard:payment-api:refund\" --workers=4",
    "e2e:test:payment-api:subscription": "npx playwright test --project \"shard:payment-api:subscription\" --workers=1",
    "e2e:test:payment-api:multistep:eur-block": "npx playwright test --project \"shard:payment-api:multistep:eur-block\" --workers=4",
    "e2e:test:payment-api:multistep:eur-classic": "npx playwright test --project \"shard:payment-api:multistep:eur-classic\" --workers=4",
    "e2e:test:payment-api:multistep:non-eur-block": "npx playwright test --project \"shard:payment-api:multistep:non-eur-block\" --workers=1",
    "e2e:test:payment-api:multistep:non-eur-classic": "npx playwright test --project \"shard:payment-api:multistep:non-eur-classic\" --workers=1",

    "e2e:test:order-api:frontend-ui": "npx playwright test --project \"shard:order-api:frontend-ui\" --workers=1",
    "e2e:test:order-api:transaction:eur-block": "npx playwright test --project \"shard:order-api:transaction:eur-block\" --workers=4",
    "e2e:test:order-api:transaction:eur-classic": "npx playwright test --project \"shard:order-api:transaction:eur-classic\" --workers=4",
    "e2e:test:order-api:transaction:non-eur-block": "npx playwright test --project \"shard:order-api:transaction:non-eur-block\" --workers=1",
    "e2e:test:order-api:transaction:non-eur-classic": "npx playwright test --project \"shard:order-api:transaction:non-eur-classic\" --workers=1",
    "e2e:test:order-api:transaction:eur-block-card-disabled-components": "npx playwright test --project \"shard:order-api:transaction:eur-block-card-disabled-components\" --workers=1",
    "e2e:test:order-api:transaction:eur-classic-card-disabled-components": "npx playwright test --project \"shard:order-api:transaction:eur-classic-card-disabled-components\" --workers=1",
    "e2e:test:order-api:refund": "npx playwright test --project \"shard:order-api:refund\" --workers=4",
    "e2e:test:order-api:subscription": "npx playwright test --project \"shard:order-api:subscription\" --workers=1",
    "e2e:test:order-api:multistep:eur-block": "npx playwright test --project \"shard:order-api:multistep:eur-block\" --workers=4",
    "e2e:test:order-api:multistep:eur-classic": "npx playwright test --project \"shard:order-api:multistep:eur-classic\" --workers=4",
    "e2e:test:order-api:multistep:non-eur-block": "npx playwright test --project \"shard:order-api:multistep:non-eur-block\" --workers=1",
    "e2e:test:order-api:multistep:non-eur-classic": "npx playwright test --project \"shard:order-api:multistep:non-eur-classic\" --workers=1",

    "e2e:env:reset": "npx playwright test --project \"setup\" --grep \"env:reset;\"",
    "e2e:env:reset:wc": "npx playwright test --project \"setup\" --grep \"env:reset;|setup:wc;\"",
    "e2e:env:reset:mollie": "npx playwright test --project \"setup\" --grep \"env:reset;|setup:wc;|setup:checkout:block;|setup:mollie:reconnected;\"",
    "e2e:env:reset:mollie:multistep": "npx playwright test --project \"setup\" --grep \"env:reset;|setup:wc;|setup:checkout:block;|setup:mollie:reconnected;|setup:multistep:checkout;\"",

    "e2e:env:setup:wc": "npx playwright test --project \"setup\" --grep \"setup:wc;\"",
    "e2e:env:setup:mollie": "npx playwright test --project \"setup\" --grep \"setup:checkout:block;|setup:mollie:reconnected;\"",
    "e2e:env:setup:payment-api": "npx playwright test --project \"setup\" --grep \"setup:payment-api;\"",
    "e2e:env:setup:order-api": "npx playwright test --project \"setup\" --grep \"setup:order-api;\"",
    "e2e:env:setup:multistep": "npx playwright test --project \"setup\" --grep \"setup:multistep:checkout;\"",
    "e2e:env:setup:checkout:block": "npx playwright test --project \"setup\" --grep \"setup:checkout:block;\"",
    "e2e:env:setup:checkout:classic": "npx playwright test --project \"setup\" --grep \"setup:checkout:classic;\"",
    "e2e:env:setup:tax:inc": "npx playwright test --project \"setup\" --grep \"setup:tax:inc;\"",
    "e2e:env:setup:tax:exc": "npx playwright test --project \"setup\" --grep \"setup:tax:exc;\"",

    "e2e:lint:md:fix": "wp-scripts lint-md-docs --fix ./tests/qa/**/*.md ./E2E-TESTS.md",
    "e2e:lint:js:fix": "wp-scripts lint-js --fix --ext .ts,.tsx,.mjs ./tests/qa"
  },
  "eslintConfig": {
    "extends": [
      "plugin:@wordpress/eslint-plugin/recommended"
    ],
    "rules": {
      "@wordpress/dependency-group": "error",
      "@wordpress/no-unsafe-wp-apis": "off",
      "no-console": "off"
    }
  }
}